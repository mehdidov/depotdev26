pipeline {
    agent any

    stages {
        stage('CleanUp de Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Cloner le GitHub') {
            steps {
                git branch: 'main', url: 'https://github.com/mehdidov/depotdev26.git'
            }
        }

        stage('Install Docker') {
            steps {
                sh 'sudo apt-get autoremove docker.io docker-compose -y'
                sh 'sudo apt-get update'
                sh 'sudo apt-get install apt-transport-https ca-certificates curl software-properties-common -y'
                sh 'sudo apt-get install docker.io -y'
                sh 'sudo apt-get update'
                sh 'sudo chmod 666 /var/run/docker.sock'
                sh 'sudo usermod -aG docker $USER'
            }
        }

        stage('build image docker') {
            steps {
                script {
                    sh 'sudo docker image rm "mynginx:latest" || true'
                    sh 'sudo docker build -t "mynginx" .'
                    sh 'sudo docker image ls'
                }
            }
        }
    } // Fin de stages
} // Fin de pipeline
