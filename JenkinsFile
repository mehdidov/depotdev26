pipeline {
    agent any

    stages {
        stage('CleanUp de Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Cloner le GitHub') {
            steps {
                git branch: 'main', url: 'https://github.com/mehdidov/depotdev26.git'
            }
        }

        stage('Fix & Start Docker') {
            steps {
                script {
                    // On essaie de redémarrer proprement sans tout réinstaller
                    // Le "|| true" permet de ne pas stopper le pipeline si une commande échoue
                    sh 'sudo systemctl stop docker.socket || true'
                    sh 'sudo systemctl stop docker.service || true'
                    sh 'sudo apt-get install docker.io -y' // S'assure juste qu'il est là
                    sh 'sudo systemctl start docker.service'
                    sh 'sudo chmod 666 /var/run/docker.sock'
                }
            }
        }

        stage('Build image Docker') {
            steps {
                script {
                    // Utilisation de sudo pour être sûr que Docker a les droits
                    sh 'sudo docker rm -f mynginx || true'
                    sh 'sudo docker build -t mynginx .'
                    sh 'sudo docker images'
                }
            }
        }
    }
}
